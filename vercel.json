{
  "functions": {
    "api/*.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/api/monthly-revenue-image",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=21600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
